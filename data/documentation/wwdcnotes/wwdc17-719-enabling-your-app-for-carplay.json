on\/wwdcnotes\/wwdc16-723-developing-carplay-systems-part-2","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-723-Developing-CarPlay-Systems-Part-2","kind":"article","role":"sampleCode","title":"Developing CarPlay Systems, Part 2","type":"topic","abstract":[{"text":"Learn how CarPlay integrates with your car’s infotainment system. Understand how CarPlay is designed to work with your car’s resources including the display, speakers, microphone, user inputs, steering wheel controls, instrument cluster and sensors.","type":"text"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-717-Developing-Wireless-CarPlay-Systems":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-717-Developing-Wireless-CarPlay-Systems","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc17-717-developing-wireless-carplay-systems","title":"Developing Wireless CarPlay Systems","kind":"article","role":"sampleCode","abstract":[{"text":"Wireless CarPlay is perfect for any trip. Get in your car without taking your iPhone out of your bag or pocket, and start experiencing CarPlay effortlessly. Learn how to design your CarPlay system to connect wirelessly to iPhone. Understand hardware requirements, best practices for a great user experience, and how to optimize the pairing and reconnection process.","type":"text"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-722-Developing-CarPlay-Systems-Part-1":{"role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc16-722-developing-carplay-systems-part-1","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-722-Developing-CarPlay-Systems-Part-1","type":"topic","title":"Developing CarPlay Systems, Part 1","kind":"article","abstract":[{"type":"text","text":"CarPlay is a smarter, safer way to use your iPhone in the car. Learn how CarPlay works and how to design your car’s infotainment system to work seamlessly with iPhone. Understand best practices for a great user experience that integrates CarPlay with the car’s native system."}]},"https://developer.apple.com/videos/play/wwdc2017/719":{"type":"download","url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2017\/719","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2017\/719","checksum":null}}}