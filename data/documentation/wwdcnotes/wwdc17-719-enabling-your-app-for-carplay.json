{"schemaVersion":{"patch":0,"major":0,"minor":3},"sampleCodeDownload":{"action":{"isActive":true,"type":"reference","overridingTitle":"Watch Video (27 min)","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2017\/719"},"kind":"sampleDownload"},"abstract":[{"type":"text","text":"Understand how to enable your audio, messaging, VoIP calling or automaker app for CarPlay. Audio, messaging and VoIP calling apps use a consistent design that’s optimized for use in the car. Automaker apps provide vehicle specific controls and displays to keep drivers connected without leaving CarPlay. Explore best practices and learn about the tools and frameworks for CarPlay apps."}],"sections":[],"metadata":{"modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC17","role":"sampleCode","title":"Enabling Your App for CarPlay"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc17-719-enabling-your-app-for-carplay"]}],"kind":"article","primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by watching the video and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}],"type":"paragraph"},{"anchor":"Related-Sessions","level":2,"type":"heading","text":"Related Sessions"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-717-Developing-Wireless-CarPlay-Systems","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-722-Developing-CarPlay-Systems-Part-1","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-723-Developing-CarPlay-Systems-Part-2"],"type":"links","