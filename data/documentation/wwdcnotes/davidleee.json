{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Indie iOS developer🧑🏻‍💻","type":"text"}],"sections":[],"kind":"article","identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/davidleee","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/Contributors"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Links","level":2,"text":"Links","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/davidleee.com","type":"reference"}]}]}],"type":"unorderedList"},{"anchor":"Contributions","level":2,"text":"Contributions","type":"heading"},{"inlineContent":[{"type":"text","text":"Contributed 7 session notes in total. Their most active year was 2025."}],"type":"paragraph"},{"anchor":"2025","level":3,"text":"2025","type":"heading"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-344-Record-replay-and-review-UI-automation-with-Xcode","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-231-Meet-WebKit-for-SwiftUI","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-278-Whats-new-in-widgets"],"type":"links","style":"list"},{"anchor":"2022","level":3,"text":"2022","type":"heading"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-110340-Design-an-effective-chart"],"type":"links","style":"list"},{"anchor":"2021","level":3,"text":"2021","type":"heading"},{"anchor":"2020","level":3,"text":"2020","type":"heading"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10671-Architecting-for-subscriptions"],"type":"links","style":"list"},{"anchor":"2019","level":3,"text":"2019","type":"heading"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-202-Using-Core-Data-With-CloudKit"],"type":"links","style":"list"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/davidleee"]}],"metadata":{"modules":[{"name":"WWDC Notes"}],"title":"David Lee (7 notes)","roleHeading":"Contributors","role":"sampleCode","images":[{"identifier":"davidleee.jpeg","type":"card"},{"identifier":"davidleee.jpeg","type":"icon"}]},"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC22-110340-Design-an-effective-chart":{"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc22-110340-design-an-effective-chart","abstract":[{"type":"text","text":"Learn how to design focused, approachable, and accessible charts. We’ll show you how to design great charts with clear marks, axes, descriptions, interaction, and color and help you create useful experiences for everyone."}],"kind":"article","role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-110340-Design-an-effective-chart","title":"Design an effective chart"},"Contributors.jpeg":{"identifier":"Contributors.jpeg","alt":null,"type":"image","variants":[{"url":"\/images\/WWDCNotes\/Contributors.jpeg","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes/Contributors":{"url":"\/documentation\/wwdcnotes\/contributors","abstract":[{"text":"WWDCNotes is only possible thanks to these awesome volunteers! Contribute now to get listed here as well.","type":"text"}],"type":"topic","kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/Contributors","role":"article","title":"Contributors","images":[{"identifier":"WWDCNotes.png","type":"icon"},{"identifier":"Contributors.jpeg","type":"card"}]},"WWDCNotes.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"identifier":"WWDCNotes.png","type":"image"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-231-Meet-WebKit-for-SwiftUI":{"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc25-231-meet-webkit-for-swiftui","type":"topic","abstract":[{"type":"text","text":"Discover how you can use WebKit to effortlessly integrate web content into your SwiftUI apps. Learn how to load and display web content, communicate with webpages, and more."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-231-Meet-WebKit-for-SwiftUI","role":"sampleCode","title":"Meet WebKit for SwiftUI"},"doc://WWDCNotes/documentation/WWDCNotes":{"kind":"symbol","title":"WWDC Notes","type":"topic","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"url":"\/documentation\/wwdcnotes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","role":"collection","images":[{"type":"icon","identifier":"WWDCNotes.png"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-344-Record-replay-and-review-UI-automation-with-Xcode":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-344-Record-replay-and-review-UI-automation-with-Xcode","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc25-344-record-replay-and-review-ui-automation-with-xcode","type":"topic","abstract":[{"type":"text","text":"Learn to record, run, and maintain XCUIAutomation tests in Xcode. Replay your XCTest UI tests in dozens of locales, device types, and system conditions using test plan configurations. Review your test results using the Xcode test report, and download screenshots and videos of your runs. We’ll also cover best practices for preparing your app for automation with Accessibility and writing stable, high-quality automation code."}],"role":"sampleCode","title":"Record, replay, and review: UI automation with Xcode"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-278-Whats-new-in-widgets":{"role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc25-278-whats-new-in-widgets","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-278-Whats-new-in-widgets","type":"topic","title":"What’s new in widgets","kind":"article","abstract":[{"text":"WidgetKit elevates your app with updates to widgets, Live Activities, and controls. Learn how to bring your widgets to visionOS, take them on the road with CarPlay, and make them look their best with accented rendering modes. Plus, find out how relevant widgets can be surfaced in the Smart Stack on watchOS, and discover how push notifications can be used to keep your widgets up to date.","type":"text"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10671-Architecting-for-subscriptions":{"abstract":[{"type":"text","text":"Learn how you can build simple entitlement logic to enhance the customer experience. We’ll dive deep into key concepts and provide guidance for architecting your systems to accurately entitle service. You’ll learn best practices for subscription features and how to craft the best customer experience throughout the subscription lifecycle."}],"kind":"article","title":"Architecting for subscriptions","role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10671-Architecting-for-subscriptions","url":"\/documentation\/wwdcnotes\/wwdc20-10671-architecting-for-subscriptions","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC19-202-Using-Core-Data-With-CloudKit":{"type":"topic","kind":"article","role":"sampleCode","abstract":[{"type":"text","text":"CloudKit offers powerful, cloud-syncing technology while Core Data provides extensive data modeling and persistence APIs. Learn about combining these complementary technologies to easily build cloud-backed applications. See how new Core Data APIs make it easy to manage the flow of data through your application, as well as in and out of CloudKit. Join us to learn more about combining these frameworks to provide a great experience across all your customers’ devices."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-202-Using-Core-Data-With-CloudKit","title":"Using Core Data With CloudKit","url":"\/documentation\/wwdcnotes\/wwdc19-202-using-core-data-with-cloudkit"},"davidleee.jpeg":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/davidleee.jpeg"}],"identifier":"davidleee.jpeg","type":"image"},"https://davidleee.com":{"identifier":"https:\/\/davidleee.com","titleInlineContent":[{"type":"text","text":"Blog"}],"url":"https:\/\/davidleee.com","type":"link","title":"Blog"}}}