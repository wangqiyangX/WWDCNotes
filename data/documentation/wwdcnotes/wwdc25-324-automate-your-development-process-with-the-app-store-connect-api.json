traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC25-324-app-development-process.jpeg"}],"type":"image"},"WWDC25-324-beta-testing-builds":{"alt":"Beta testing builds","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC25-324-beta-testing-builds.jpeg"}],"type":"image","identifier":"WWDC25-324-beta-testing-builds"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-328-Whats-new-in-App-Store-Connect":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-328-Whats-new-in-App-Store-Connect","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc25-328-whats-new-in-app-store-connect","title":"What’s new in App Store Connect","kind":"article","role":"sampleCode","abstract":[{"type":"text","text":"Get the latest updates for App Store Connect, including the new web UI for build delivery and enhancements to TestFlight notifications. We’ll also discuss new app discovery features and enhancements, such as keywords for custom product pages, Accessibility Nutrition Labels, and age ratings updates. Additionally, learn about new functionalities like In-App Purchase offer codes and review summarization tools."}]},"WWDC25-324-tester-feedback.jpeg":{"type":"image","identifier":"WWDC25-324-tester-feedback.jpeg","alt":"Feedback API","variants":[{"url":"\/images\/WWDCNotes\/WWDC25-324-tester-feedback.jpeg","traits":["1x","light"]}]},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"text":"Contributions are welcome!","type":"text"}],"title":"Contributions are welcome!","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link"},"WWDC25-324-create-builduploadfiles-request.jpeg":{"alt":"Create BuildUploadFiles request","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC25-324-create-builduploadfiles-request.jpeg"}],"type":"image","identifier":"WWDC25-324-create-builduploadfiles-request.jpeg"},"WWDCNotes.png":{"type":"image","identifier":"WWDCNotes.png","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]},"WWDC25-324-webhook-notification.jpeg":{"identifier":"WWDC25-324-webhook-notification.jpeg","alt":"Webhook notification","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC25-324-webhook-notification.jpeg"}],"type":"image"},"VictorPuga.jpeg":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/VictorPuga.jpeg"}],"type":"image","identifier":"VictorPuga.jpeg"},"WWDC25.jpg":{"type":"image","identifier":"WWDC25.jpg","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC25.jpg","traits":["1x","light"]}]},"https://x.com/victorpugaruiz":{"identifier":"https:\/\/x.com\/victorpugaruiz","titleInlineContent":[{"text":"X\/Twitter","type":"text"}],"title":"X\/Twitter","url":"https:\/\/x.com\/victorpugaruiz","type":"link"},"VictorPuga":{"alt":"Profile image of Victor Manuel Puga Ruiz","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/VictorPuga.jpeg"}],"type":"image","identifier":"VictorPuga"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-325-Discover-AppleHosted-Background-Assets":{"title":"Discover Apple-Hosted Background Assets","url":"\/documentation\/wwdcnotes\/wwdc25-325-discover-applehosted-background-assets","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-325-Discover-AppleHosted-Background-Assets","kind":"article","role":"sampleCode","abstract":[{"text":"Building on Background Assets, this session will introduce the new capability to download asset packs of content for games and other applications. Learn how Apple can host these asset packs for you or how to manage self-hosting options. We’ll delve into the native API integration and the corresponding App Store implementations, providing you with the tools to enhance your app’s content delivery and user experience.","type":"text"}]}}}