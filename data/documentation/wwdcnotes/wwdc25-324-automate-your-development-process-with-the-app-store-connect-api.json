{"sections":[],"metadata":{"modules":[{"name":"WWDC Notes"}],"title":"Automate your development process with the App Store Connect API","roleHeading":"WWDC25","role":"sampleCode"},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-324-Automate-your-development-process-with-the-App-Store-Connect-API","interfaceLanguage":"swift"},"kind":"article","hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Summary","type":"heading","anchor":"Summary"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"The App Store Connect API has been updated to enhance automation in app development processes.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"New features include the Webhooks API, BuildUpload API, and Feedback API.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Webhooks provide push notifications for app-related events, improving efficiency by replacing constant polling.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The Build upload API enables automated build uploads with structured error handling."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"TestFlight APIs automate beta testing processes, including build distribution and review notifications.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The Feedback API allows developers to quickly receive and act on tester feedback, including screenshots and crash reports."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Recommendations include setting up webhook listeners and leveraging additional API capabilities for faster development cycles."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-324-app-development-process.jpeg","type":"image"}]},{"level":2,"text":"Presenters","type":"heading","anchor":"Presenters"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dajinsol Jeon, App Store Connect Team"}]}]}]},{"level":2,"text":"Webhook Notifications","type":"heading","anchor":"Webhook-Notifications"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Webhook notifications transform traditional API polling into push communication between servers.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"They allow the creation of event-driven workflows, enhancing efficiency.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"App Store Connect sends notifications directly to your server when specified app-related events occur.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Supported events:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"TestFlight feedback submission"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"App version state"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Build upload state"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Build beta state"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple-Hosted Background Assets state"}]}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"To set up, provide App Store Connect with the URL of your webhook listener (an HTTP server).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Upon relevant changes, App Store Connect sends a POST request to the registered URL with event information.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"This year’s webhook notifications include events like new TestFlight feedback submissions and build state changes.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Notifications include a signature for verifying authenticity, using a secret key shared only with App Store Connect."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-324-create-webhook-form.jpeg"}]},{"level":2,"text":"BuildUpload API","type":"heading","anchor":"BuildUpload-API"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The BuildUpload API automates the process of uploading builds to App Store Connect.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"It is part of the standardized App Store Connect APIs, allowing integration with any language or platform."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The API provides detailed error messages to assist with automated error handling."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"To use the API:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Start by creating a BuildUpload with build version and target platform details."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Next, provide the details of your build file using BuildUploadFiles.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"App Store Connect gives instructions on how to upload your build, including URL and headers."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Large builds may require multiple HTTP calls for uploading in chunks.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"After uploading, notify App Store Connect by marking the upload as complete, triggering build processing."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Webhook notifications inform you immediately when build processing is complete.","type":"text"}]}]}],"type":"unorderedList"}]}]},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-324-build-upload-api-steps.jpeg","type":"image"}]},{"tabs":[{"title":"1. Create BuildUploads","content":[{"type":"row","columns":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-324-create-builduploads-request.jpeg"}]}],"size":1},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-324-create-builduploads-response.jpeg"}]}],"size":1}],"numberOfColumns":2}]},{"title":"2. Create BuildUploadFiles","content":[{"numberOfColumns":2,"type":"row","columns":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-324-create-builduploadfiles-request.jpeg","type":"image"}]}],"size":1},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-324-create-builduploadfiles-response.jpeg"}]}],"size":1}]}]},{"title":"3. Complete BuildUploadFiles","content":[{"numberOfColumns":2,"columns":[{"size":1,"content":[{"inlineContent":[{"type":"image","identifier":"WWDC25-324-complete-builduploadfiles-request.jpeg"}],"type":"paragraph"}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-324-complete-builduploadfiles-response.jpeg"}]}]}],"type":"row"}]},{"title":"4. Webhook Notification","content":[{"numberOfColumns":2,"columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-324-webhook-notification.jpeg"}]}]},{"size":1,"content":[]}],"type":"row"}]}],"type":"tabNavigator"},{"level":2,"text":"Beta Testing Builds","type":"heading","anchor":"Beta-Testing-Builds"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Once a build is processed by App Store Connect, it can be distributed to beta testers using TestFlight.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Builds can be assigned directly to specific beta tester groups.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"External testers require the build to pass Beta App Review before distribution."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Notifications to testers about new builds can be automated using TestFlight APIs."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The build beta state webhook event notifies developers when TestFlight beta review is complete."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The webhook payload includes the updated state and specific build ID, indicating readiness for external testing.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-324-beta-testing-builds"}]},{"level":2,"text":"Feedback API","type":"heading","anchor":"Feedback-API"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The Feedback API allows developers to retrieve tester feedback quickly and efficiently.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"It supports both screenshot feedback for UI issues and crash feedback for app crashes."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Receiving feedback promptly enables faster responses, improving user experience.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Webhook events notify developers of new feedback submissions as they occur.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"A feedback notification contains minimal information, including feedback type and related instance ID."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The Feedback API can be used to retrieve detailed information about feedback submissions.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Screenshot URLs included in the feedback can be used to download images programmatically.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Crash feedback can be retrieved similarly, with crash logs accessible via the crashLog endpoint.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-324-tester-feedback.jpeg"}]},{"level":2,"text":"Additional Development APIs","type":"heading","anchor":"Additional-Development-APIs"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"New APIs are available to automate asset management for Apple-Hosted Background Assets."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"App version state webhook events notify developers about changes in the app’s state on the App Store.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"These APIs complete the development process from initial development through testing to release.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"App Store Connect offers many existing APIs to automate various stages of the development workflow."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Automating daily tasks with these APIs allows developers to focus more on enhancing user experience."}]}]}]},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-324-app-store-connect-api-features.jpeg","type":"image"}]},{"level":1,"text":"Recommendations","type":"heading","anchor":"Recommendations"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Build webhook listeners so that you can receive webhook notifications from App Store Connect."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Implement reactive behaviors based on webhook events to automate your processes.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Explore what else the App Store Connect API offers and use these APIs in your automation for an even faster development cycle","type":"text"}],"type":"paragraph"}]}]},{"level":2,"text":"Written By","type":"heading","anchor":"Written-By"},{"type":"row","numberOfColumns":5,"columns":[{"size":1,"content":[{"inlineContent":[{"identifier":"VictorPuga","type":"image"}],"type":"paragraph"}]},{"size":4,"content":[{"text":"Victor Manuel Puga Ruiz","anchor":"Victor-Manuel-Puga-Ruiz","level":3,"type":"heading"},{"inlineContent":[{"overridingTitle":"Contributed Notes","overridingTitleInlineContent":[{"type":"text","text":"Contributed Notes"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/VictorPuga","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"|","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/github.com\/VictorPuga","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"|","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/www.victorpuga.com","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"|","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/x.com\/victorpugaruiz","type":"reference","isActive":true}],"type":"paragraph"}]}]},{"type":"thematicBreak"},{"type":"paragraph","inlineContent":[{"text":"Missing anything? Corrections? ","type":"text"},{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true,"type":"reference"}]},{"level":2,"text":"Related Sessions","type":"heading","anchor":"Related-Sessions"},{"type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-325-Discover-AppleHosted-Background-Assets","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-328-Whats-new-in-App-Store-Connect"],"style":"list"},{"type":"small","inlineContent":[{"inlineContent":[{"text":"Legal Notice","type":"text"}],"type":"strong"